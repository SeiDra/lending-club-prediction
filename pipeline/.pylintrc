# ── .pylintrc ──────────────────────────────────────────────────────────────

[MASTER]
# Parallélisme pour accélérer l'analyse
jobs = 1

# Extensions utiles
load-plugins =

# Ignorer les dossiers non pertinents
ignore = mlruns, DATA, .venv, __pycache__, .ipynb_checkpoints

[MESSAGES CONTROL]

disable =
    # -- Style & Conventions --
    C0103,  # invalid-name (pour autoriser X, c, niv)
    C0114, C0115, C0116, # missing-docstrings (on ne veut pas documenter chaque fonction)
    C0301,  # line-too-long (pour tes blocs HTML/CSS de Streamlit)
    C0302,  # too-many-lines
    C3001,  # unnecessary-lambda-assignment (pour tes lambdas lbl, rc, etc.)

    # -- Refactoring & Complexité --
    R0801, R0902, R0903, R0912, R0913, R0914, R0915,

    # -- Warnings --
    W0621,  # redefined-outer-name (pour tes variables f, s, stats utilisées partout)
    
    # -- Autres --
    E0401   # import-error (géré par la CI) 

[FORMAT]
# Aligné avec Black
max-line-length = 100
indent-string = '    '

[DESIGN]
# Seuils assouplis pour le code ML/Streamlit
max-args = 10
max-locals = 20
max-returns = 8
max-branches = 15
max-statements = 60
max-attributes = 10

[SIMILARITIES]
# Éviter les faux positifs sur du code répétitif (feature engineering)
min-similarity-lines = 10
ignore-imports = yes
ignore-docstrings = yes

[VARIABLES]
# Noms courts courants en data science
good-names = i, j, k, x, y, X, df, ax, fig, f, v, s, c, p, g, r

[REPORTS]
# Format compact pour la CI
output-format = colorized
reports = no
score = yes
